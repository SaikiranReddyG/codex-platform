# codex-platform local configuration template
# Copy to .env and edit for your environment.

# Workspace layout
CODEX_COMPOSE_DIR=/absolute/path/to/codex-platform
CODEX_ARCH_WORKSPACE=/absolute/path/to/codex-workspace
CODEX_ARCH_LOG_DIR=/absolute/path/to/codex-workspace/codex-platform/logs

# Hosts and users
CODEX_LOCAL_HOST=YOUR_LOCAL_HOST
CODEX_ARCH_IP=YOUR_ARCH_VM_IP
CODEX_ARCH_USER=YOUR_ARCH_VM_USER
CODEX_POPOS_IP=YOUR_POPOS_IP

# Ports
CODEX_MQTT_PORT=YOUR_MQTT_PORT
CODEX_REDIS_PORT=YOUR_REDIS_PORT
CODEX_N8N_PORT=YOUR_N8N_PORT
CODEX_GRAFANA_PORT=YOUR_GRAFANA_PORT

# Database path
CODEX_SQLITE_DB=/absolute/path/to/codex-platform/sqlite/codex.db

# Credentials
CODEX_MQTT_USER=YOUR_MQTT_USER
CODEX_MQTT_PASS=YOUR_MQTT_PASSWORD
CODEX_REDIS_PASS=YOUR_REDIS_PASSWORD
CODEX_GRAFANA_ADMIN_USER=YOUR_GRAFANA_USER
CODEX_GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD

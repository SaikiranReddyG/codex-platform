{
  "__inputs": [
    {
      "name": "DS_REDIS",
      "label": "Redis",
      "description": "Redis datasource for live streams",
      "type": "datasource",
      "pluginId": "redis-datasource",
      "pluginName": "Redis"
    },
    {
      "name": "DS_SQLITE",
      "label": "SQLite",
      "description": "SQLite datasource for historical data",
      "type": "datasource",
      "pluginId": "frser-sqlite-datasource",
      "pluginName": "SQLite"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "type": "row",
      "title": "Status overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },

    {
      "type": "stat",
      "title": "Active nodes",
      "description": "Distinct sources that have reported events",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(DISTINCT source) as value FROM events WHERE created_at > datetime('now', '-7 days')",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#fc5c65", "value": null },
              { "color": "#f6ad55", "value": 1 },
              { "color": "#38d9a9", "value": 2 }
            ]
          },
          "mappings": [],
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },

    {
      "type": "stat",
      "title": "Containers",
      "description": "Docker services on Pop!_OS",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT 4 as value",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#63b3ed" },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },

    {
      "type": "stat",
      "title": "MQTT topics",
      "description": "Distinct MQTT topics seen in events",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(DISTINCT mqtt_topic) as value FROM events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#f6ad55" },
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },

    {
      "type": "stat",
      "title": "Alerts (24h)",
      "description": "Total alerts in the last 24 hours",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(*) as value FROM events WHERE event_type = 'alert' AND created_at > datetime('now', '-24 hours')",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#38d9a9", "value": null },
              { "color": "#f6ad55", "value": 10 },
              { "color": "#fc5c65", "value": 25 }
            ]
          },
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },

    {
      "type": "stat",
      "title": "Critical (24h)",
      "description": "Critical severity alerts in last 24 hours",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(*) as value FROM events WHERE severity = 'critical' AND created_at > datetime('now', '-24 hours')",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#fc5c65" },
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },

    {
      "type": "stat",
      "title": "Last alert",
      "description": "Time of most recent alert",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT MAX(timestamp) as time FROM events WHERE event_type = 'alert'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#b794f6" },
          "unit": "none",
          "noValue": "No alerts yet"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },

    {
      "type": "row",
      "title": "Live feeds",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": []
    },

    {
      "type": "table",
      "title": "Live alert stream (Redis)",
      "description": "Real-time alerts from Redis stream — shows last 50 entries. If empty, sentinel is not running or no alerts have been generated.",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 6 },
      "id": 10,
      "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
      "targets": [
        {
          "type": "redis",
          "command": "xrange",
          "keyName": "stream:codex/sentinel/alerts",
          "start": "-",
          "end": "+",
          "count": 50,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": true,
            "filterable": true
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false },
        "sortBy": []
      }
    },

    {
      "type": "piechart",
      "title": "Alerts by severity",
      "description": "Distribution of alert severity levels across all time",
      "gridPos": { "h": 10, "w": 5, "x": 14, "y": 6 },
      "id": 11,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT severity, COUNT(*) as count FROM events WHERE event_type = 'alert' GROUP BY severity ORDER BY CASE severity WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 WHEN 'low' THEN 4 END",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#fc5c65", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#f6ad55", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "medium" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#63b3ed", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "low" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#38d9a9", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": [], "fields": "/^count$/" },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "displayLabels": ["percent"]
      }
    },

    {
      "type": "table",
      "title": "Threat intelligence",
      "description": "Known attack signatures from intel.yaml",
      "gridPos": { "h": 10, "w": 5, "x": 19, "y": 6 },
      "id": 12,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT attack_type, severity, response_action FROM threat_intel ORDER BY CASE severity WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 WHEN 'low' THEN 4 END",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "text": "🔴 critical" }, "high": { "text": "🟠 high" }, "medium": { "text": "🟡 medium" }, "low": { "text": "🟢 low" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "response_action" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "alert": { "text": "⚡ alert" }, "log": { "text": "📝 log" }, "mitigate": { "text": "🛡️ mitigate" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      }
    },

    {
      "type": "row",
      "title": "Alert timeline & history",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "panels": []
    },

    {
      "type": "state-timeline",
      "title": "Alert timeline by severity",
      "description": "Visual timeline showing when alerts fired and their severity",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 17 },
      "id": 20,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT timestamp as time, CASE severity WHEN 'critical' THEN 4 WHEN 'high' THEN 3 WHEN 'medium' THEN 2 WHEN 'low' THEN 1 ELSE 0 END as severity_level, json_extract(payload, '$.data.detection_type') as detection FROM events WHERE event_type = 'alert' ORDER BY timestamp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "#38d9a9", "value": 1 },
              { "color": "#63b3ed", "value": 2 },
              { "color": "#f6ad55", "value": 3 },
              { "color": "#fc5c65", "value": 4 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "none" }, "1": { "text": "low" }, "2": { "text": "medium" }, "3": { "text": "high" }, "4": { "text": "critical" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "rowHeight": 0.8,
        "mergeValues": false,
        "alignValue": "center",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },

    {
      "type": "barchart",
      "title": "Alerts by detection type",
      "description": "Count of each detection type from sentinel",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 21,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT json_extract(payload, '$.data.detection_type') as detection_type, COUNT(*) as count FROM events WHERE event_type = 'alert' AND json_extract(payload, '$.data.detection_type') IS NOT NULL GROUP BY detection_type ORDER BY count DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#63b3ed" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 0,
            "axisCenteredZero": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#63b3ed", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "xTickLabelRotation": 0,
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden", "showLegend": false }
      }
    },

    {
      "type": "table",
      "title": "Alert history (detailed)",
      "description": "Full historical alert log from SQLite",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 22,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT timestamp, severity, json_extract(payload, '$.data.detection_type') as detection, json_extract(payload, '$.data.src_ip') as src_ip, json_extract(payload, '$.data.dst_ip') as dst_ip, json_extract(payload, '$.data.message') as message FROM events WHERE event_type = 'alert' ORDER BY timestamp DESC LIMIT 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": true,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "text": "🔴 CRITICAL" }, "high": { "text": "🟠 HIGH" }, "medium": { "text": "🟡 MEDIUM" }, "low": { "text": "🟢 LOW" } } }
                ]
              },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "timestamp" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": true, "countRows": true, "reducer": ["count"] },
        "sortBy": [{ "displayName": "timestamp", "desc": true }]
      }
    },

    {
      "type": "row",
      "title": "Data flow",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "panels": []
    },

    {
      "type": "table",
      "title": "MQTT data flow status",
      "description": "Active MQTT topics with event counts and last seen time",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 32 },
      "id": 30,
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT mqtt_topic as topic, source, COUNT(*) as event_count, MAX(timestamp) as last_seen FROM events GROUP BY mqtt_topic ORDER BY last_seen DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "topic" },
            "properties": [
              { "id": "custom.width", "value": 280 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      }
    }

  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["codex", "security", "soc"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d"]
  },
  "timezone": "browser",
  "title": "SOC Command Center",
  "uid": "codex-soc-v2",
  "version": 1,
  "weekStart": ""
}

      "options": {
        "SVGBaseFix": true,
        "add100Percentage": true,
        "calcsMutation": "standard",
        "centerAlignContent": true,
        "codeData": "{\n  \"text\": \"Random text\"\n}",
        "css": "* {\n  font-family: Open Sans;\n}\n\n.box {\n  border: solid #555 2px;\n  border-radius: 10px;\n  padding: 10px 20px;\n}\n",
        "dynamicData": false,
        "dynamicFieldDisplayValues": false,
        "dynamicHtmlGraphics": false,
        "dynamicProps": false,
        "html": "\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  \n  :root {\n    --bg-surface: #111827;\n    --bg-card: #1a2235;\n    --border: rgba(99, 179, 237, 0.12);\n    --text-primary: #e8edf5;\n    --text-secondary: #8b95a8;\n    --text-muted: #5a6478;\n    --accent-blue: #63b3ed;\n    --accent-teal: #38d9a9;\n    --accent-amber: #f6ad55;\n    --accent-red: #fc5c65;\n    --accent-purple: #b794f6;\n  }\n  \n  .topo-wrap {\n    width: 100%;\n    height: 100%;\n    display: flex;\n    flex-direction: column;\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', monospace;\n    background: transparent;\n  }\n  \n  .topo-stats {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 1px;\n    background: rgba(99,179,237,0.06);\n    border-bottom: 1px solid var(--border);\n    flex-shrink: 0;\n  }\n  \n  .topo-stat {\n    padding: 10px 12px;\n    background: var(--bg-surface);\n  }\n  \n  .topo-stat-label {\n    font-size: 9px;\n    color: var(--text-muted);\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n  }\n  \n  .topo-stat-value {\n    font-size: 20px;\n    font-weight: 600;\n    margin-top: 2px;\n  }\n  \n  .topo-stat-unit {\n    font-size: 10px;\n    font-weight: 400;\n    color: var(--text-muted);\n  }\n  \n  .topo-graph {\n    flex: 1;\n    padding: 16px;\n    min-height: 0;\n  }\n  \n  .topo-graph svg {\n    width: 100%;\n    height: 100%;\n  }\n  \n  .topo-flows {\n    border-top: 1px solid var(--border);\n    flex-shrink: 0;\n    overflow-x: auto;\n  }\n  \n  .flow-hdr, .flow-row {\n    display: grid;\n    grid-template-columns: 2.5fr 1.8fr 1.8fr 1fr 0.8fr;\n    padding: 6px 12px;\n    font-size: 10px;\n    white-space: nowrap;\n  }\n  \n  .flow-hdr {\n    color: var(--text-muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    background: rgba(99,179,237,0.04);\n    font-size: 9px;\n  }\n  \n  .flow-row {\n    border-top: 1px solid rgba(99,179,237,0.06);\n    color: var(--text-secondary);\n  }\n  \n  .flow-row:hover { background: rgba(99,179,237,0.04); }\n  .flow-topic { color: var(--accent-blue); }\n  .flow-rate { color: var(--accent-teal); }\n  \n  .flow-status {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n  \n  .dot {\n    width: 5px;\n    height: 5px;\n    border-radius: 50%;\n    display: inline-block;\n  }\n  .dot-active { background: var(--accent-teal); }\n  .dot-standby { background: var(--accent-amber); }\n  \n  @keyframes nodeIn {\n    from { opacity: 0; transform: translateY(4px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n  .node-anim { animation: nodeIn 0.5s ease-out both; }\n</style>\n\n<div class=\"topo-wrap\">\n  \n  <!-- Stats bar -->\n  <div class=\"topo-stats\">\n    <div class=\"topo-stat\">\n      <div class=\"topo-stat-label\">Active nodes</div>\n      <div class=\"topo-stat-value\" style=\"color:var(--accent-teal)\">2 <span class=\"topo-stat-unit\">/ 2</span></div>\n    </div>\n    <div class=\"topo-stat\">\n      <div class=\"topo-stat-label\">Containers</div>\n      <div class=\"topo-stat-value\" style=\"color:var(--accent-blue)\">4 <span class=\"topo-stat-unit\">healthy</span></div>\n    </div>\n    <div class=\"topo-stat\">\n      <div class=\"topo-stat-label\">MQTT topics</div>\n      <div class=\"topo-stat-value\" style=\"color:var(--accent-amber)\">3 <span class=\"topo-stat-unit\">active</span></div>\n    </div>\n    <div class=\"topo-stat\">\n      <div class=\"topo-stat-label\">Alerts 24h</div>\n      <div class=\"topo-stat-value\" style=\"color:var(--accent-red)\">17</div>\n    </div>\n  </div>\n  \n  <!-- Topology graph -->\n  <div class=\"topo-graph\">\n    <svg viewBox=\"0 0 920 300\" xmlns=\"http://www.w3.org/2000/svg\">\n      <defs>\n        <marker id=\"arr\" viewBox=\"0 0 10 10\" refX=\"10\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto\">\n          <path d=\"M0 1L8 5L0 9\" fill=\"none\" stroke=\"context-stroke\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n        </marker>\n      </defs>\n      \n      <!-- Subtle grid -->\n      <pattern id=\"grid\" width=\"40\" height=\"40\" patternUnits=\"userSpaceOnUse\">\n        <circle cx=\"20\" cy=\"20\" r=\"0.5\" fill=\"rgba(99,179,237,0.06)\"/>\n      </pattern>\n      <rect width=\"920\" height=\"300\" fill=\"url(#grid)\"/>\n      \n      <!-- Zone labels -->\n      <text x=\"170\" y=\"18\" font-size=\"9\" fill=\"#5a6478\" text-anchor=\"middle\" letter-spacing=\"0.12em\" font-family=\"monospace\">SENSOR ZONE</text>\n      <line x1=\"70\" y1=\"24\" x2=\"270\" y2=\"24\" stroke=\"rgba(99,179,237,0.06)\" stroke-width=\"1\"/>\n      \n      <text x=\"470\" y=\"18\" font-size=\"9\" fill=\"#5a6478\" text-anchor=\"middle\" letter-spacing=\"0.12em\" font-family=\"monospace\">PROCESSING ZONE</text>\n      <line x1=\"340\" y1=\"24\" x2=\"600\" y2=\"24\" stroke=\"rgba(99,179,237,0.06)\" stroke-width=\"1\"/>\n      \n      <text x=\"780\" y=\"18\" font-size=\"9\" fill=\"#5a6478\" text-anchor=\"middle\" letter-spacing=\"0.12em\" font-family=\"monospace\">OUTPUT ZONE</text>\n      <line x1=\"700\" y1=\"24\" x2=\"860\" y2=\"24\" stroke=\"rgba(99,179,237,0.06)\" stroke-width=\"1\"/>\n      \n      <!-- ═══ CONNECTIONS ═══ -->\n      <path d=\"M260 80 L340 80\" fill=\"none\" stroke=\"#63b3ed\" stroke-width=\"1.5\" opacity=\"0.3\" marker-end=\"url(#arr)\"/>\n      <path d=\"M260 80 C300 80,310 170,340 170\" fill=\"none\" stroke=\"#fc5c65\" stroke-width=\"1\" opacity=\"0.2\" marker-end=\"url(#arr)\" stroke-dasharray=\"4 3\"/>\n      <path d=\"M260 170 C300 170,310 95,340 95\" fill=\"none\" stroke=\"#38d9a9\" stroke-width=\"1\" opacity=\"0.25\" marker-end=\"url(#arr)\"/>\n      <path d=\"M260 250 C310 250,320 105,340 105\" fill=\"none\" stroke=\"#f6ad55\" stroke-width=\"1\" opacity=\"0.15\" marker-end=\"url(#arr)\" stroke-dasharray=\"4 3\"/>\n      \n      <path d=\"M500 90 L540 90 L540 170 L580 170\" fill=\"none\" stroke=\"#63b3ed\" stroke-width=\"1.5\" opacity=\"0.3\" marker-end=\"url(#arr)\"/>\n      <path d=\"M500 175 L520 175 L520 250 L580 250\" fill=\"none\" stroke=\"#38d9a9\" stroke-width=\"1\" opacity=\"0.25\" marker-end=\"url(#arr)\"/>\n      \n      <path d=\"M735 170 L770 170 L770 95 L800 95\" fill=\"none\" stroke=\"#b794f6\" stroke-width=\"1\" opacity=\"0.3\" marker-end=\"url(#arr)\"/>\n      <path d=\"M735 250 L800 250\" fill=\"none\" stroke=\"#f6ad55\" stroke-width=\"1\" opacity=\"0.2\"/>\n      \n      <!-- ═══ NODES ═══ -->\n      \n      <!-- Sentinel -->\n      <g class=\"node-anim\" style=\"animation-delay:0.1s\">\n        <rect x=\"90\" y=\"42\" width=\"170\" height=\"75\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(99,179,237,0.25)\" stroke-width=\"1\"/>\n        <circle cx=\"106\" cy=\"60\" r=\"4\" fill=\"#38d9a9\"/>\n        <text x=\"118\" y=\"64\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">sentinel</text>\n        <text x=\"106\" y=\"82\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">IDS · br-lab</text>\n        <text x=\"106\" y=\"100\" font-size=\"9\" fill=\"#63b3ed\" font-family=\"monospace\">→ alerts + dual-write</text>\n      </g>\n      \n      <!-- Syswatch -->\n      <g class=\"node-anim\" style=\"animation-delay:0.15s\">\n        <rect x=\"90\" y=\"132\" width=\"170\" height=\"75\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(56,217,169,0.25)\" stroke-width=\"1\"/>\n        <circle cx=\"106\" cy=\"150\" r=\"4\" fill=\"#38d9a9\"/>\n        <text x=\"118\" y=\"154\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">syswatch</text>\n        <text x=\"106\" y=\"172\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">/proc · 5s interval</text>\n        <text x=\"106\" y=\"190\" font-size=\"9\" fill=\"#38d9a9\" font-family=\"monospace\">→ metrics stream</text>\n      </g>\n      \n      <!-- Netlab -->\n      <g class=\"node-anim\" style=\"animation-delay:0.2s\">\n        <rect x=\"90\" y=\"222\" width=\"170\" height=\"60\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(246,173,85,0.2)\" stroke-width=\"1\"/>\n        <circle cx=\"106\" cy=\"240\" r=\"4\" fill=\"#f6ad55\"/>\n        <text x=\"118\" y=\"244\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">netlab</text>\n        <text x=\"106\" y=\"262\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">attack sim · ns-atk</text>\n      </g>\n      \n      <!-- Mosquitto -->\n      <g class=\"node-anim\" style=\"animation-delay:0.3s\">\n        <rect x=\"340\" y=\"42\" width=\"160\" height=\"80\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(99,179,237,0.25)\" stroke-width=\"1\"/>\n        <circle cx=\"356\" cy=\"60\" r=\"4\" fill=\"#38d9a9\"/>\n        <text x=\"368\" y=\"64\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">Mosquitto</text>\n        <text x=\"356\" y=\"82\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">MQTT · :1883</text>\n        <text x=\"356\" y=\"100\" font-size=\"9\" fill=\"#8b95a8\" font-family=\"monospace\">3 topics</text>\n      </g>\n      \n      <!-- Redis -->\n      <g class=\"node-anim\" style=\"animation-delay:0.35s\">\n        <rect x=\"340\" y=\"140\" width=\"160\" height=\"70\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(252,92,101,0.2)\" stroke-width=\"1\"/>\n        <circle cx=\"356\" cy=\"158\" r=\"4\" fill=\"#38d9a9\"/>\n        <text x=\"368\" y=\"162\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">Redis</text>\n        <text x=\"356\" y=\"180\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">streams · :6379</text>\n        <text x=\"356\" y=\"196\" font-size=\"9\" fill=\"#fc5c65\" font-family=\"monospace\">3 active streams</text>\n      </g>\n      \n      <!-- n8n -->\n      <g class=\"node-anim\" style=\"animation-delay:0.4s\">\n        <rect x=\"580\" y=\"132\" width=\"155\" height=\"75\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(183,148,246,0.25)\" stroke-width=\"1\"/>\n        <circle cx=\"596\" cy=\"150\" r=\"4\" fill=\"#38d9a9\"/>\n        <text x=\"608\" y=\"154\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">n8n</text>\n        <text x=\"596\" y=\"172\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">workflows · :5678</text>\n        <text x=\"596\" y=\"190\" font-size=\"9\" fill=\"#b794f6\" font-family=\"monospace\">2 active</text>\n      </g>\n      \n      <!-- Grafana -->\n      <g class=\"node-anim\" style=\"animation-delay:0.45s\">\n        <rect x=\"580\" y=\"222\" width=\"155\" height=\"60\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(246,173,85,0.2)\" stroke-width=\"1\"/>\n        <circle cx=\"596\" cy=\"240\" r=\"4\" fill=\"#38d9a9\"/>\n        <text x=\"608\" y=\"244\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">Grafana</text>\n        <text x=\"596\" y=\"262\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">SQLite+Redis · :3000</text>\n      </g>\n      \n      <!-- Discord -->\n      <g class=\"node-anim\" style=\"animation-delay:0.5s\">\n        <rect x=\"800\" y=\"68\" width=\"90\" height=\"50\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(183,148,246,0.2)\" stroke-width=\"1\"/>\n        <circle cx=\"816\" cy=\"86\" r=\"4\" fill=\"#b794f6\"/>\n        <text x=\"828\" y=\"90\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">Discord</text>\n        <text x=\"816\" y=\"106\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">ai-lab</text>\n      </g>\n      \n      <!-- Sweep label -->\n      <g class=\"node-anim\" style=\"animation-delay:0.5s\">\n        <rect x=\"800\" y=\"222\" width=\"90\" height=\"50\" rx=\"8\" fill=\"#1a2235\" stroke=\"rgba(56,217,169,0.2)\" stroke-width=\"1\"/>\n        <circle cx=\"816\" cy=\"240\" r=\"4\" fill=\"#38d9a9\"/>\n        <text x=\"828\" y=\"244\" font-size=\"11\" font-weight=\"600\" fill=\"#e8edf5\" font-family=\"monospace\">SQLite</text>\n        <text x=\"816\" y=\"262\" font-size=\"9\" fill=\"#5a6478\" font-family=\"monospace\">cold store</text>\n      </g>\n\n      <!-- Host labels -->\n      <rect x=\"90\" y=\"294\" width=\"170\" height=\"0\" rx=\"0\" fill=\"none\"/>\n      <text x=\"175\" y=\"296\" font-size=\"8\" fill=\"#5a6478\" text-anchor=\"middle\" font-family=\"monospace\" letter-spacing=\"0.05em\">ARCH VM · 192.168.1.51</text>\n      \n      <text x=\"500\" y=\"296\" font-size=\"8\" fill=\"#5a6478\" text-anchor=\"middle\" font-family=\"monospace\" letter-spacing=\"0.05em\">POP!_OS · 192.168.1.50</text>\n    </svg>\n  </div>\n  \n  <!-- Flow table -->\n  <div class=\"topo-flows\">\n    <div class=\"flow-hdr\">\n      <span>Topic</span>\n      <span>Source</span>\n      <span>Consumer</span>\n      <span>Status</span>\n      <span>Rate</span>\n    </div>\n    <div class=\"flow-row\">\n      <span class=\"flow-topic\">codex/sentinel/alerts</span>\n      <span>sentinel (Arch)</span>\n      <span>n8n, Redis</span>\n      <span class=\"flow-status\"><span class=\"dot dot-active\"></span> active</span>\n      <span class=\"flow-rate\">~3/min</span>\n    </div>\n    <div class=\"flow-row\">\n      <span class=\"flow-topic\">codex/syswatch/metrics</span>\n      <span>syswatch (Arch)</span>\n      <span>metrics_receiver</span>\n      <span class=\"flow-status\"><span class=\"dot dot-active\"></span> active</span>\n      <span class=\"flow-rate\">12/min</span>\n    </div>\n    <div class=\"flow-row\">\n      <span class=\"flow-topic\">codex/netlab/attacks</span>\n      <span>run_attack.py</span>\n      <span>Redis</span>\n      <span class=\"flow-status\"><span class=\"dot dot-standby\"></span> standby</span>\n      <span class=\"flow-rate\">on trigger</span>\n    </div>\n  </div>\n</div>\n",
        "onInit": "",
        "onInitOnResize": false,
        "onRender": "",
        "overflow": "hidden",
        "panelupdateOnMount": true,
